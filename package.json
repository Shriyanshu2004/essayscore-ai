{
  "name": "essayscore-ai",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run frontend\" --names \"BACKEND,FRONTEND\" --prefix-colors \"bgBlue.bold,bgMagenta.bold\" --kill-others",
    "backend": "cd backend && python main.py",
    "frontend": "cd frontend && npm run dev",
    "build": "cd frontend && npm install && npm run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
